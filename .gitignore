# Dependencies
node_modules/

# Build output (regenerated by `npm run build`)
dist/

# Test build output (regenerated by `npm test`)
dist-test/

# MCPB bundle output (regenerated by `npm run build:mcpb`).
# mcpb/manifest.json and mcpb/icon.png ARE committed; the rest is generated.
mcpb/server/
*.mcpb

# Secrets — never commit
.env
.env.*
!.env.example
.token-seal-key
.dcr-clients.json
.dcr-clients.json.tmp
.simpro-tokens.json
.simpro-tokens.json.tmp

# Logs
*.log
npm-debug.log*

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
