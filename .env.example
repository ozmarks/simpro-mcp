# Copy to .env and fill in. Never commit .env. See README.md for full setup.
SIMPRO_BASE_URL=https://your-build.simprosuite.com
SIMPRO_COMPANY_ID=0
# Server Mode: stdio (default) | proxy (bearer auth passthrough) | broker (OAuth Broker).
 SIMPRO_TRANSPORT=stdio

# --- stdio (local) ---------------------------------------------------------

# Auth mode: authorization_code | client_credentials | api_key. If unset it's
# inferred (client_credentials when both client id+secret are present, else
# api_key), so existing setups keep working.
#SIMPRO_AUTH_MODE=authorization_code

# Simpro OAuth credentials. Required for BOTH authorization_code and
# client_credentials. Create an OAuth API application in Simpro and set BOTH.
#SIMPRO_CLIENT_ID=
#SIMPRO_CLIENT_SECRET=

# authorization_code only: a one-time browser login per machine. Simpro issues a
# refresh token (cached to .simpro-tokens.json, mode 0600, in the state dir) so
# users don't re-authorise every restart. ONE registered localhost redirect URI
# (http://localhost:<port>/callback) must exist on the Simpro app. Pre-seed/refresh
# with `npm run login`; the server also auto-runs the flow at startup if uncached.
#SIMPRO_AUTH_REDIRECT_PORT=8237
# Authorize endpoint (defaults to SIMPRO_BASE_URL + /oauth2/login). Change only if required.
#SIMPRO_AUTH_URL=
# Token endpoint (defaults to SIMPRO_BASE_URL + /oauth2/token). Change only if required.
#SIMPRO_TOKEN_URL=

# Legacy SIMPRO API Key (stdio mode only; deprecated by Simpro). Used only when
# SIMPRO_AUTH_MODE=api_key (or no client credentials are set). Server refuses to
# run in HTTP modes if set.
#SIMPRO_API_KEY=

# --- HTTP transport --------------------------------------------------------

# PORT=3000
# HOST=0.0.0.0
# MCP_PATH=/mcp
# DNS-rebinding protection (defense-in-depth). Comma/space-separated allow-lists
# for the Host and Origin headers on /mcp. Protection is OFF unless at least one
# is set; when set, requests with a non-matching Host/Origin get 403. The broker
# mode seeds the Host list with PUBLIC_URL's host automatically.
# MCP_ALLOWED_HOSTS=simpro-mcp:3000
# MCP_ALLOWED_ORIGINS=

# --- Tuning ----------------------------------------------------------------
# SIMPRO_DEFAULT_PAGE_SIZE=50
# SIMPRO_MAX_RESULT_BYTES=100000

# --- OAuth broker (Claude connector) ---------------------------------------
# Required when SIMPRO_TRANSPORT=broker.
# PUBLIC_URL=https://mcp.example.com
# SIMPRO_CLIENT_ID=
# SIMPRO_CLIENT_SECRET=
# Token Seal Key (random 32+ byte hex string; required for to encrypt Oauth tokens at rest. Keep secret)
# TOKEN_SEAL_KEY=
# Default to SIMPRO_BASE_URL + /oauth2/login and /oauth2/token . Change only if required.
# SIMPRO_AUTH_URL=
# SIMPRO_TOKEN_URL=
# Confidential downstream connectors (client_secret_post). Optional; CIMD clients
# like Claude need no entry here. JSON array; client_id must NOT be a URL.
# STATIC_CLIENTS=[{"client_id":"my-connector","client_secret":"<long-random>","redirect_uris":["https://connector.example.com/callback"]}]
# Grace window (ms) the broker holds a rotated Simpro refresh token so a client that
# dropped a refresh response can still recover. Default 600000 (10 min); only needs to
# outlive a refresh round-trip. In-memory, single-instance.
# SIMPRO_REFRESH_GRACE_TTL_MS=600000
# The broker persists its state (auto-generated seal key, open-DCR clients) to
# /data when that dir exists (the container creates it), else beside the build.
# Map a durable volume onto /data in containers or DCR clients re-register after
# every restart. There's no env knob for the path.