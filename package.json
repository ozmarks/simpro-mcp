{
  "name": "simpro-mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial MCP server exposing Simpro operations (quotes, jobs, customers, catalog, aggregations) over stdio and streamable HTTP. Not affiliated with, endorsed by, or supported by Simpro.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozmarks/simpro-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ozmarks/simpro-mcp/issues"
  },
  "homepage": "https://github.com/ozmarks/simpro-mcp#readme",
  "bin": {
    "simpro-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-data.mjs",
    "build-index": "node scripts/build-index.mjs",
    "copy-data": "node scripts/copy-data.mjs",
    "start": "node dist/index.js",
    "login": "node dist/login.js",
    "dev": "tsc --watch",
    "test": "tsc -p tsconfig.test.json && node scripts/copy-data.mjs dist-test && node --test \"dist-test/test/**/*.test.js\"",
    "build:mcpb": "node scripts/build-mcpb.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.1.0",
    "undici": "^7.27.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
